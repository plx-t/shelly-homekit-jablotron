# mos.yml — PATCH for Shelly 1 G3 Jablotron SecuritySystem build
#
# Apply this as a diff against the upstream mos.yml.
# The only change inside the Shelly1Gen3 model block is adding
# "src" to include shelly_hap_security_system.cpp from the top-level src/.
#
# Context lines (unchanged) shown with leading space.
# Added lines shown with leading +
#
# ─────────────────────────────────────────────────────────────────────────────
# --- a/mos.yml
# +++ b/mos.yml
# @@ -N,6 +N,8 @@
#    - when: build_vars.MODEL == "Shelly1Gen3"
#      apply:
#        name: S1G3
#        sources:
#          - src/DS18XXX
#          - src/DHT
#          - src/ShellyPlus1
#+         - src                    # picks up shelly_hap_security_system.cpp
#        libs:
# ─────────────────────────────────────────────────────────────────────────────
#
# FULL replacement block for the Shelly1Gen3 section:

  - when: build_vars.MODEL == "Shelly1Gen3"
    apply:
      name: S1G3
      sources:
        - src/DS18XXX
        - src/DHT
        - src/ShellyPlus1
        - src                          # <-- ADDED: compiles shelly_hap_security_system.cpp
      libs:
        - location: https://github.com/mongoose-os-libs/onewire
        - location: https://github.com/mongoose-os-libs/dht
        - location: https://github.com/mongoose-os-libs/mongoose
      build_vars:
        OTA_DATA_ADDR: 0x10000
        OTA_DATA_SIZE: 0x4000
        NVS_ADDR: 0x14000
        NVS_SIZE: 0xC000
        APP_OFFSET: 0x20000
        APP_SLOT_SIZE: 0x280000
        MGOS_ROOT_FS_TYPE: LFS
        MGOS_ROOT_FS_SIZE: 1048576
        ESP_IDF_EXTRA_PARTITION: "scratch,data,0x80,0x720000,0x80000,encrypted"
        ESP_IDF_EXTRA_PARTITION_2: "shelly,data,0x88,0x7F0000,64K,encrypted"
        ESP_IDF_SDKCONFIG_OPTS: >
          ${build_vars.ESP_IDF_SDKCONFIG_OPTS}
            CONFIG_FREERTOS_UNICORE=y
